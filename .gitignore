# WordPress コアファイル（wp.orgから再取得可能なため管理不要）
/wp-admin/
/wp-includes/
/wp-*.php
!/wp-config-sample.php
/license.txt
/readme.html

# アップロードファイル
/wp-content/uploads/

# キャッシュ・アップグレード関連
/wp-content/cache/
/wp-content/upgrade/
/wp-content/backup-db/
/wp-content/advanced-cache.php
/wp-content/object-cache.php

# テーマ
# 親テーマ・デフォルトテーマは配布元から取得できるため無視し、
# 実装対象の子テーマ（cocoon-child-master）のみ管理する
/wp-content/themes/*
!/wp-content/themes/cocoon-child-master/

# プラグイン
# サードパーティ配布物は無視。自作プラグインを追加したら個別に許可すること
# 例: !/wp-content/plugins/my-original-plugin/
/wp-content/plugins/*

# 設定・シークレット
.env
wp-config.php
sitemap.xml
sitemap.gz

# Local (Local by Flywheel) 環境固有ファイル
.htaccess
local-xdebuginfo.php

# システム・OS関連
.DS_Store
Thumbs.db
*.log
